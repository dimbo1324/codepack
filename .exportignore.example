# Project export rules: copied into a project root as .exportignore when users need custom filters.
# Similar to .gitignore. Use !pattern to explicitly include custom-ignored files.

# Heavy dependency/build folders are excluded by default because they waste AI context.
node_modules/
.git/
dist/
build/

# Generated logs, archives, databases, and local secrets should stay out of shared export bundles.
*.log
*.zip
*.rar
*.7z
*.db
*.sqlite
.env*
private/
large-assets/

# Explicit include examples:
# !README.md
# !docs/
