# Repository hygiene: keep generated caches, local secrets, and export artifacts out of Git.
# The application creates large ZIP/staging folders during smoke tests and manual exports.

__pycache__/
*.py[cod]
*$py.class

# Local virtual environments are machine-specific and can contain absolute paths.
.venv/
venv/
env/
ENV/

# Test, lint, and coverage caches are reproducible and should not be reviewed.
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Build outputs are generated by PyInstaller/Inno Setup and are published as release artifacts.
/dist/
/build/ProjectExporterDesktop/
/build/pyinstaller/__pycache__/
*.egg-info/

# Local app settings may include user paths and workflow preferences.
*.log
.project_exporter_desktop.json
.project_exporter_profiles.json

# Secrets and private key material must never enter the repository.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# IDE/editor state is local noise.
.vscode/
.idea/
*.swp
*.swo

# OS metadata files are not meaningful for the project.
.DS_Store
Thumbs.db

# Export bundles are generated outputs and can be very large.
*_export_*.zip
*_export_*/
*_export_*_archives/

# Temporary smoke-test and local export folders.
.tmp/
exports/
